rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // collectionGroup("approved_articles") / collectionGroup("pending_submissions") need this pattern:
    match /{path=**}/approved_articles/{articleId} {
      allow read, write: if request.auth != null;
    }
    match /{path=**}/pending_submissions/{submissionId} {
      allow read, write: if request.auth != null;
    }

    match /article_reactions/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
